/**
 * For more details on how to configure Wrangler, refer to:
 * https://developers.cloudflare.com/workers/wrangler/configuration/
 */
{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "lesapay",
	"main": "server/index.ts",
	"compatibility_date": "2026-05-17",
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true,
	"compatibility_flags": [
		"nodejs_compat"
	],
	/**
	 * Static assets — the frontend in `./client` is served by the Worker,
	 * so the Worker URL hosts both the SPA and the API on the same origin.
	 * `run_worker_first` ensures /api requests reach the Worker even though
	 * /index.html exists in the assets bundle.
	 */
	"assets": {
		"directory": "./client",
		"binding": "ASSETS",
		"run_worker_first": ["/api", "/api/*"]
	}
}